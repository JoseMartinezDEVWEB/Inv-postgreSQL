{
  "cli": {
    "version": ">= 7.6.0",
    "appVersionSource": "remote",
    "requireCommit": false
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "http://localhost:4501/api",
        "EAS_BUILD_GRADLE_UNIVERSAL_APK": "1"
      }
    },
    "production": {
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "http://localhost:4501/api",
        "EAS_BUILD_GRADLE_UNIVERSAL_APK": "1"
      }
    },
    "production-local": {
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "http://localhost:4501/api",
        "EAS_BUILD_GRADLE_UNIVERSAL_APK": "1"
      }
    }
  },
  "submit": {
    "production": {}
  }
}